# Hoarder (bookmark manager) environment configuration
# Copy to app.env and customize before starting

# Timezone
TZ=America/New_York

# Public URL
BASE_HOST_NAME=hoarder.example.com

# NextAuth secret (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Meilisearch master key (min 16 chars)
MEILI_MASTER_KEY=changeme_meili_master_key_min_16_chars
